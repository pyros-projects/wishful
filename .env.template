# wishful configuration via environment variables.
# Copy to .env (gitignored) and fill in. All settings are optional except an
# LLM API key for your chosen provider. configure(...) overrides these at runtime.

# --- LLM provider (any litellm-supported backend) ---
OPENAI_API_KEY="your-openai-api-key-here"
# AZURE_API_KEY=...
# ANTHROPIC_API_KEY=...

# --- Model selection ---
# WISHFUL_MODEL takes precedence over DEFAULT_MODEL; both are litellm model ids.
WISHFUL_MODEL="openai/gpt-5.5"
# DEFAULT_MODEL="openai/gpt-4.1"            # fallback when WISHFUL_MODEL is unset

# --- Generation behavior ---
# WISHFUL_MAX_TOKENS="16384"                # max response tokens (reasoning models
#                                           #   spend part of the budget on hidden
#                                           #   tokens, so keep this generous)
# WISHFUL_TEMPERATURE="1.0"                 # sampling temperature
# WISHFUL_REQUEST_TIMEOUT="300"             # per-call timeout in seconds
# WISHFUL_SYSTEM_PROMPT="..."               # override the system prompt (advanced)
# WISHFUL_CONTEXT_RADIUS="3"                # lines of surrounding code captured
#                                           #   around each import/call site

# --- Cache ---
# WISHFUL_CACHE_DIR=".wishful"              # where generated modules are cached

# --- Explore ---
# WISHFUL_EXPLORE_SAVE_RESULTS="1"          # "0" suppresses the per-run CSVs that
#                                           #   explore() writes under <cache_dir>/_explore/

# --- Safety & review (important for headless/agent use) ---
# WISHFUL_UNSAFE="0"                        # "1" disables the safety validator (dangerous)
# WISHFUL_REVIEW="0"                        # "1" prompts before executing generated code;
#                                           #     requires an interactive terminal/notebook
# WISHFUL_FAKE_LLM="0"                      # "1" returns deterministic stubs (CI/offline)
# WISHFUL_SPINNER="1"                       # "0" disables the generating spinner

# --- Logging ---
# WISHFUL_DEBUG="0"                         # "1" enables DEBUG logging
# WISHFUL_LOG_LEVEL="WARNING"               # DEBUG | INFO | WARNING | ERROR
# WISHFUL_LOG_TO_FILE="0"                   # "1" writes logs under <cache_dir>/_logs
# WISHFUL_LOG_PROMPTS="0"                   # "1" logs prompt/context bodies (may contain source/secrets) at DEBUG
